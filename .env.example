# ACRGE Lite runtime configuration
# Copy this file to .env for local development only.
# Never commit real secrets.

APP_ENV=dev
APP_NAME=acrge-lite
LOG_LEVEL=INFO

# Azure identity and tenancy
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=

# Foundry / Azure OpenAI
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME_GPT4O=gpt-4o
FOUNDRY_MODEL_DEPLOYMENT_NAME_GPT4O_MINI=gpt-4o-mini
FOUNDRY_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Ingestion / messaging
ACRGE_INBOUND_TOPIC=acrge.events.inbound
SERVICEBUS_FULLY_QUALIFIED_NAMESPACE=
SERVICEBUS_CONNECTION_STRING=

# Cosmos DB
COSMOS_ENDPOINT=
COSMOS_DATABASE_NAME=acrge
COSMOS_INCIDENTS_CONTAINER=incidents
COSMOS_AUDIT_CONTAINER=audit

# Redis semantic cache
REDIS_HOST=
REDIS_PORT=6380
REDIS_SSL=true
REDIS_PASSWORD=
REDIS_TTL_SECONDS=900

# Blob storage
BLOB_ACCOUNT_URL=
BLOB_CONTAINER_RAW_LOGS=acrge-raw-logs
BLOB_CONTAINER_ARTIFACTS=acrge-artifacts

# Azure AI Search
AI_SEARCH_ENDPOINT=
AI_SEARCH_INDEX_INCIDENTS=acrge-incidents
AI_SEARCH_API_KEY=

# Key Vault / App Config
KEY_VAULT_URL=
APP_CONFIG_ENDPOINT=
APP_CONFIG_POLICY_KEY=acrge/policies/governance

# Azure DevOps integration
AZDO_ORG_URL=
AZDO_PROJECT=
AZDO_REPO_ID=
AZDO_PAT=

# Teams notifier
TEAMS_WEBHOOK_URL=

# Feature controls
AUTO_REMEDIATION_ENABLED=false
HUMAN_APPROVAL_REQUIRED_DEFAULT=true

# Telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=acrge-lite
